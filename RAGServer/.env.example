# ─────────────────────────────────────────────
# RAGServer — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────

# OpenAI API key (required)
OPENAI_API_KEY=your-openai-api-key-here

# Pinecone API key and index name
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_INDEX_NAME=rag-chat-bot

# Admin secret key — sent as X-Admin-Key header from the frontend admin panel.
# Change this to a strong random string in production!
ADMIN_SECRET_KEY=change-me-in-production

# Path to prompts JSON file (relative to where you run the server)
PROMPTS_FILE=prompts.json

# Path to SQLite conversations database
CONVERSATIONS_DB=conversations.db
